# Environment variables
# Copy this file to .env.secret and fill in the values
# Don't commit .env.secret to the repository

# Frontend
FRONTEND_PORT=5173
# VITE_API_URL is auto-detected — set only if you need a custom backend URL
# VITE_API_URL=https://your-api.example.com

# Backend
BACKEND_PORT=8000

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nlex_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Trino
TRINO_PORT=8080

# Admin
ADMIN_EMAIL=admin@nlex.ai
ADMIN_PASSWORD=admin123

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM
OPENAI_API_KEY=your-openai-api-key-change-me
OPENAI_BASE_URL=https://api.openai.com/v1
# Model for SQL query generation (used per user request)
LLM_MODEL_SQL=gpt-5.4-mini
# Model for database relationship inference (used once during schema sync)
LLM_MODEL_INFERENCE=gpt-5.4-mini
MAX_SQL_RETRIES=3
SYSTEM_PROXY_URL=

# CORS — comma-separated allowed origins for the backend API.
# Default covers localhost for development. Add your production domain(s) here.
CORS_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1:5173
