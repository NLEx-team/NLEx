# Environment variables
# Copy this file to .env.secret and fill in the values
# Don't commit .env.secret to the repository

# Frontend
FRONTEND_PORT=5173

# Backend
BACKEND_PORT=8000

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nlex_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}