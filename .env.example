# Environment variables
# Copy this file to .env.secret and fill in the values
# Don't commit .env.secret to the repository

# Frontend
FRONTEND_PORT=5173
VITE_API_URL=https://api.nlex.tech

# Backend
BACKEND_PORT=8000

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nlex_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Trino
TRINO_PORT=8080

# Admin
ADMIN_EMAIL=admin@nlex.ai
ADMIN_PASSWORD=admin123

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 hours

# LLM
OPENAI_API_KEY=your-openai-api-key-change-me
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL_FAST=gpt-5.4-mini
LLM_MODEL_THINKING=gpt-5.5
MAX_SQL_RETRIES=3
SYSTEM_PROXY_URL=
